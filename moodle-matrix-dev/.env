# Ruta del vault de Obsidian en el host (WSL o Linux).
# Esta variable se usa en docker-compose.yml para montar la carpeta OKF-Vault
# dentro del contenedor moodle-app en /obsidian-vault.
#
# Ajusta la ruta si tu vault esta en otro lugar.
# En WSL: usa la ruta de montaje /mnt/c/... aunque Obsidian la vea como C:\...
#
# Si no usas la integracion con Obsidian, puedes dejar esta variable vacia
# o borrar la linea del volumen en docker-compose.yml.
OBSIDIAN_VAULT_PATH=/mnt/c/Users/julia/Documents/OKF-Vault
